cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m4"
    nvic: nvic

nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    priorityMask: 0xF0
    systickFrequency: 25000000
    IRQ -> cpu@0

flash: Memory.MappedMemory @ sysbus 0x01000000
    size: 0x00200000

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x00040000

uart0: UART.CMSDK_APB_UART @ sysbus 0x49303000

dwt: Miscellaneous.DWT @ sysbus 0xE0001000
    frequency: 25000000
